DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

OPENAI_API_KEY=your_openai_key
OPENAI_BASE_URL=https://api.openai.com/v1
IMAGE_MODEL=gpt-image-2
IMAGE_SIZE=2560x1440
IMAGE_QUALITY=medium

OUTPUT_DIR=/data/jobs
MAX_ACTIVE_JOBS=1
MAX_IMAGE_CONCURRENCY_PER_JOB=5
MAX_IMAGE_RETRIES=2
MAX_QUEUED_JOBS=20

DEFAULT_PAGE_COUNT=8
MIN_PAGE_COUNT=1
MAX_PAGE_COUNT=30

# Optional. Set this before exposing the service outside a private network.
API_TOKEN=
CORS_ALLOW_ORIGINS=*

# Optional. Used only while building the Docker image.
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
